# TravelOS Environment Variables
# Copy this file to .env.local and fill in your values

# Required: Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Web Search (choose one or both)
TAVILY_API_KEY=your_tavily_api_key_here
EXA_API_KEY=your_exa_api_key_here

# Optional: Unsplash (https://unsplash.com/developers) — falls back to Picsum if absent
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# RapidAPI accommodation router
# Shared key fallback. Provider-specific keys below override this when present.
RAPIDAPI_KEY=your_rapidapi_key_here

# Booking.com via Tipsters CO
RAPIDAPI_BOOKING_HOST=booking-provider-host-from-rapidapi
RAPIDAPI_BOOKING_SEARCH_PATH=/v1/hotels/search-by-coordinates

# Priceline via Tipsters CO
RAPIDAPI_PRICELINE_HOST=priceline-provider-host-from-rapidapi
RAPIDAPI_PRICELINE_SEARCH_PATH=/v1/hotels/search-by-coordinates

# Expedia via apiheya
RAPIDAPI_EXPEDIA_HOST=expedia-provider-host-from-rapidapi
RAPIDAPI_EXPEDIA_SEARCH_PATH=/hotels/search

# Airbnb / Homes via Vibe pro
RAPIDAPI_AIRBNB_HOST=airbnb-provider-host-from-rapidapi
RAPIDAPI_AIRBNB_SEARCH_PATH=/search
